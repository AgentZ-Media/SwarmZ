{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SwarmZ",
  "version": "0.5.0",
  "identifier": "de.agent-z.swarmz",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SwarmZ",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 10, "y": 23 },
        "backgroundColor": "#0a0a0c"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; media-src 'self' blob:; connect-src ipc: http://ipc.localhost; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Run and monitor a swarm of native Codex agents.",
    "longDescription": "SwarmZ — run and monitor parallel native Codex agents (codex app-server sessions) with structured transcripts, diffs and approvals. App state stays local; model traffic goes to OpenAI via the Codex CLI.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/AgentZ-Media/SwarmZ/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwOTA2MzVGQ0FCQUY3OTIKUldTUzk3cktYMk9Rb0pCZHRtREZoTDl0eWtwN2pEclJNeHpRRUJUUEtqVEluSmZSK2V2Q1NRMHgK"
    }
  }
}
