{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SwarmZ",
  "version": "0.1.1",
  "identifier": "de.agent-z.swarmz",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SwarmZ",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0a0a0c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Run, tile and monitor a swarm of Claude Code agents.",
    "longDescription": "SwarmZ — run, tile and monitor parallel Claude Code agents in real terminals, with live token and cost tracking. 100% local.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/AgentZ-Media/SwarmZ/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwOTA2MzVGQ0FCQUY3OTIKUldTUzk3cktYMk9Rb0pCZHRtREZoTDl0eWtwN2pEclJNeHpRRUJUUEtqVEluSmZSK2V2Q1NRMHgK"
    }
  }
}
