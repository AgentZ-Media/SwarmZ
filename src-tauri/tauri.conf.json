{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SwarmZ",
  "version": "0.1.0",
  "identifier": "com.timocorvinus.swarmz",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SwarmZ",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0a0a0c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
